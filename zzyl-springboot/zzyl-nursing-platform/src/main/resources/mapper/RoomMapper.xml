<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzyl.nursing.mapper.RoomMapper">

    <resultMap type="Room" id="RoomResult">
        <result property="id"         column="id" />
        <result property="floorId"    column="floor_id" />
        <result property="roomNumber" column="room_number" />
        <result property="sortOrder"  column="sort_order" />
        <result property="status"     column="status" />
        <result property="remark"     column="remark" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="createBy"   column="create_by" />
        <result property="updateBy"   column="update_by" />
    </resultMap>

    <resultMap type="com.zzyl.nursing.domain.vo.RoomVo" id="RoomVoResult">
        <result property="floorName"  column="floor_name" />
        <result property="roomNumber" column="room_number" />
        <result property="bedNumber"  column="bed_number" />
        <result property="price"      column="price" />
    </resultMap>

    <sql id="selectRoomVo">
        select id, floor_id, room_number, sort_order, status,
               remark, create_time, update_time, create_by, update_by
        from room
    </sql>

    <select id="selectRoomList" parameterType="Room" resultMap="RoomResult">
        <include refid="selectRoomVo"/>
        <where>
            <if test="floorId != null"> and floor_id = #{floorId}</if>
            <if test="roomNumber != null and roomNumber != ''"> and room_number like concat('%', #{roomNumber}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort_order
    </select>

    <select id="selectRoomById" parameterType="Long" resultMap="RoomResult">
        <include refid="selectRoomVo"/>
        where id = #{id}
    </select>

    <!-- 根据床位ID查询楼栋名称、房间号、床位号、价格 -->
    <select id="selectRoomVoByBedId" parameterType="Long" resultMap="RoomVoResult">
        select
            f.name as floor_name,
            r.room_number,
            b.bed_number,
            b.price
        from bed b
        left join room r on b.room_id = r.id
        left join floor f on r.floor_id = f.id
        where b.id = #{bedId}
    </select>

    <insert id="insertRoom" parameterType="Room" useGeneratedKeys="true" keyProperty="id">
        insert into room
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="floorId != null">floor_id,</if>
            <if test="roomNumber != null and roomNumber != ''">room_number,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="floorId != null">#{floorId},</if>
            <if test="roomNumber != null and roomNumber != ''">#{roomNumber},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
        </trim>
    </insert>

    <update id="updateRoom" parameterType="Room">
        update room
        <trim prefix="SET" suffixOverrides=",">
            <if test="floorId != null">floor_id = #{floorId},</if>
            <if test="roomNumber != null">room_number = #{roomNumber},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRoomById" parameterType="Long">
        delete from room where id = #{id}
    </delete>

    <delete id="deleteRoomByIds" parameterType="String">
        delete from room where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
